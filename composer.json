{
    "name": "lrc/handicapping",
    "description": "LRC Spreadsheet Export / Handicapping CLI",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "phpoffice/phpspreadsheet": "^5.7"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "App\\Services\\": "app/Services/",
            "App\\Console\\": "app/Console/"
        },
        "classmap": [
            "src/legacy/"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "preferred-install": "source",
        "sort-packages": true
    }
}
