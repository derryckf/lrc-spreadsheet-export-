# LRC Handicapping — Environment Variables
#
# Copy this file to .env and edit values.

# Database connection (MySQL on port 3307)
DB_HOST=127.0.0.1
DB_PORT=3307
DB_DATABASE=lacsite_deploy
DB_USERNAME=lrcuser
DB_PASSWORD=lrcpassword

# Google Drive integration (optional — only needed for --gdrive flag)
# Path to service account JSON key file.
# See: https://console.cloud.google.com/apis/credentials → Service Account
GOOGLE_DRIVE_CREDENTIALS=/path/to/lrc-handicapping-service-account.json
# ID of the Drive folder where spreadsheets are stored.
# Share this folder with the service account email.
GOOGLE_DRIVE_FOLDER_ID=
